<odoo>

    <record id="privilege_hr_hospital" model="res.groups.privilege">
        <field name="name">Hospital Management</field>
        <field name="description">Helps you manage hospital operations.</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_hr_hospital_patient" model="res.groups">
        <field name="name">Patient</field>
        <field name="privilege_id" ref="privilege_hr_hospital"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hr_hospital_intern" model="res.groups">
        <field name="name">Intern</field>
        <field name="privilege_id" ref="privilege_hr_hospital"/>
        <field name="implied_ids" eval="[(4, ref('hr_hospital.group_hr_hospital_patient'))]"/>
    </record>

    <record id="group_hr_hospital_doctor" model="res.groups">
        <field name="name">Doctor</field>
        <field name="privilege_id" ref="privilege_hr_hospital"/>
        <field name="implied_ids" eval="[(4, ref('hr_hospital.group_hr_hospital_intern'))]"/>
    </record>

    <record id="group_hr_hospital_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_hr_hospital"/>
        <field name="implied_ids" eval="[(4, ref('hr_hospital.group_hr_hospital_doctor'))]"/>
    </record>

    <record id="group_hr_hospital_administrator" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="privilege_hr_hospital"/>
        <field name="implied_ids" eval="[(4, ref('hr_hospital.group_hr_hospital_manager'))]"/>
        <field name="user_ids" eval="[
                                    (4, ref('base.user_root')),
                                    (4, ref('base.user_admin'))
                                ]"/>
        <!--        <field name="user_ids" eval="[-->
        <!--                    Command.link(ref('base.user_root')),-->
        <!--                    Command.link(ref('base.user_admin'))-->
        <!--                ]"/>-->
    </record>

</odoo>
